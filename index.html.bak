const CATEGORIES = ["All", "Bangla", "Documentary", "English", "Entertainment", "Hindi", "Hindi Movies", "Infotainment", "Kids", "Latest", "Movies", "Music", "News", "Religious", "Sports", "Unknown", "Weather"];

/* =============================================
   STATE
   ============================================= */
let currentCat = "All";
let searchQuery = "";
let currentChannel = null;
let favorites = JSON.parse(localStorage.getItem("bf_favs") || "[]");
let recentList = JSON.parse(localStorage.getItem("bf_recent") || "[]");
let deferredPrompt = null;
let currentView = "home";

/* =============================================
   PWA INSTALL
   ============================================= */
window.addEventListener("beforeinstallprompt", (e) => {
  e.preventDefault();
  deferredPrompt = e;
  document.getElementById("installBtn").classList.remove("hidden");
  // Show toast after 3s
  setTimeout(() => {
    if (!localStorage.getItem("bf_install_dismissed")) {
      document.getElementById("installToast").classList.remove("hidden");
    }
  }, 3000);
});

window.addEventListener("appinstalled", () => {
  document.getElementById("installBtn").classList.add("hidden");
  document.getElementById("installToast").classList.add("hidden");
  deferredPrompt = null;
});

async function triggerInstall() {
  if (deferredPrompt) {
    deferredPrompt.prompt();
    const { outcome } = await deferredPrompt.userChoice;
    deferredPrompt = null;
    if (outcome === "accepted") {
      document.getElementById("installBtn").classList.add("hidden");
      document.getElementById("installToast").classList.add("hidden");
    }
  } else {
    // Show manual instructions
    alert("📱 ইনস্টল করতে:\n\nAndroid Chrome: মেনু (⋮) → \"হোম স্ক্রিনে যোগ করুন\"\niPhone Safari: Share (⬆️) → \"Add to Home Screen\"\nDesktop: Address bar এর ডানে ইনস্টল আইকনে ক্লিক করুন");
  }
}

document.getElementById("installBtn").addEventListener("click", triggerInstall);
document.getElementById("toastInstallBtn").addEventListener("click", triggerInstall);

function dismissToast() {
  document.getElementById("installToast").classList.add("hidden");
  localStorage.setItem("bf_install_dismissed", "1");
}

function openInstall() { triggerInstall(); closeSidebar(); }

/* =============================================
   SERVICE WORKER
   ============================================= */
if ("serviceWorker" in navigator) {
  window.addEventListener("load", () => {
    navigator.serviceWorker.register("./sw.js").catch(() => {});
  });
}

/* =============================================
   SIDEBAR TOGGLE
   ============================================= */
function toggleSidebar() {
  const s = document.getElementById("sidebar");
  const o = document.getElementById("sidebarOverlay");
  s.classList.toggle("open");
  o.classList.toggle("visible");
}
function closeSidebar() {
  document.getElementById("sidebar").classList.remove("open");
  document.getElementById("sidebarOverlay").classList.remove("visible");
}
document.getElementById("hamburgerBtn").addEventListener("click", toggleSidebar);
document.getElementById("sidebarOverlay").addEventListener("click", closeSidebar);

/* =============================================
   VIEWS
   ============================================= */
function setView(view, el) {
  currentView = view;
  document.querySelectorAll(".view").forEach(v => v.classList.remove("active"));
  document.getElementById("view-" + view).classList.add("active");
  document.querySelectorAll(".sidebar-nav-item").forEach(i => i.classList.remove("active"));
  if (el) el.classList.add("active");
  else {
    const match = document.querySelector(`.sidebar-nav-item[data-view="${view}"]`);
    if (match) match.classList.add("active");
  }
  if (view === "favorites") renderFavs();
  if (view === "recent") renderRecent();
  if (view === "all") renderAll();
  closeSidebar();
  window.scrollTo({ top: 0 });
}

function setActiveBottomNav(id) {
  document.querySelectorAll(".bottom-nav-item").forEach(i => i.classList.remove("active"));
  document.getElementById(id).classList.add("active");
}

/* =============================================
   FILTER & RENDER
   ============================================= */
function buildFilterTabs() {
  const tabs = document.getElementById("filterTabs");
  tabs.innerHTML = "";
  CATEGORIES.forEach(cat => {
    const el = document.createElement("button");
    el.className = "cat-chip" + (cat === currentCat ? " active" : "");
    el.textContent = cat === "All" ? "🌐 সব" : catEmoji(cat) + " " + cat;
    el.onclick = () => { currentCat = cat; buildFilterTabs(); renderHome(); };
    tabs.appendChild(el);
  });
}

function buildSidebarCats() {
  const wrap = document.getElementById("sidebarCats");
  wrap.innerHTML = "";
  CATEGORIES.forEach(cat => {
    const el = document.createElement("button");
    el.className = "cat-chip" + (cat === currentCat ? " active" : "");
    el.textContent = cat === "All" ? "🌐 সব" : catEmoji(cat) + " " + cat;
    el.onclick = () => {
      currentCat = cat;
      buildFilterTabs();
      buildSidebarCats();
      setView("home");
      renderHome();
    };
    wrap.appendChild(el);
  });
}

function catEmoji(cat) {
  return {Bangla:"🇧🇩", News:"📰", Sports:"⚽", Kids:"🧒", Music:"🎵", English:"🌍", Movies:"🎬", Entertainment:"📺", Hindi:"🇮🇳", 'Hindi Movies':"🎥", Religious:"🕌", Documentary:"🎞️", Infotainment:"💡", Weather:"⛅", Latest:"🆕", Unknown:"📡"}[cat] || "📺";
}

function getFiltered() {
  let list = currentCat === "All" ? CHANNELS : CHANNELS.filter(c => c.cat === currentCat);
  if (searchQuery) {
    const q = searchQuery.toLowerCase();
    list = list.filter(c => c.name.toLowerCase().includes(q) || c.cat.toLowerCase().includes(q));
  }
  return list;
}

function renderChannelCard(channel, container) {
  const isFav = favorites.includes(channel.id);
  const isPlaying = currentChannel && currentChannel.id === channel.id;
  const div = document.createElement("div");
  div.className = "channel-card" + (isPlaying ? " playing" : "") + (channel.fifa ? " fifa-highlight" : "");
  div.dataset.id = channel.id;
  div.onclick = () => playChannel(channel);
  div.innerHTML = `
    <div class="channel-thumb">
      <img src="${channel.logo}" alt="${channel.name}" loading="lazy" onerror="this.src='https://img.icons8.com/color/96/tv.png'"/>
      <div class="thumb-overlay"></div>
      <div class="live-dot">LIVE</div>
      ${channel.fifa ? '<div class="fifa-badge">⚽ FIFA 2026</div>' : ''}
      <button class="fav-btn ${isFav ? "active" : ""}" title="পছন্দে যোগ করুন" onclick="toggleFav(event, ${channel.id})">${isFav ? "❤️" : "🤍"}</button>
      <div class="play-overlay">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="white" opacity="0.9"><circle cx="12" cy="12" r="12" fill="rgba(229,9,20,0.85)"/><polygon points="10,8 16,12 10,16" fill="white"/></svg>
      </div>
    </div>
    <div class="channel-info">
      <div class="channel-name">${channel.name}</div>
      <div class="channel-cat">${catEmoji(channel.cat)} ${channel.cat}</div>
    </div>
  `;
  container.appendChild(div);
}

function renderGrid(list, containerId, emptyMsg) {
  const grid = document.getElementById(containerId);
  grid.innerHTML = "";
  if (!list.length) {
    grid.innerHTML = `<div class="empty-state"><div class="emoji">${emptyMsg.emoji}</div><p>${emptyMsg.text}</p></div>`;
    return;
  }
  list.forEach(ch => renderChannelCard(ch, grid));
}

function renderHome() {
  const list = getFiltered();
  document.getElementById("sectionTitle").textContent = currentCat === "All" ? "সব চ্যানেল" : catEmoji(currentCat) + " " + currentCat;
  document.getElementById("sectionCount").textContent = list.length + " টি চ্যানেল";
  renderGrid(list, "channelGrid", { emoji: "🔍", text: "কোনো চ্যানেল পাওয়া যায়নি" });
}

function renderFavs() {
  const list = CHANNELS.filter(c => favorites.includes(c.id));
  document.getElementById("favCount").textContent = list.length + " টি চ্যানেল";
  renderGrid(list, "favGrid", { emoji: "💔", text: "এখনো কোনো পছন্দের চ্যানেল নেই। হার্ট আইকনে ক্লিক করুন।" });
}

function renderRecent() {
  const list = recentList.map(id => CHANNELS.find(c => c.id === id)).filter(Boolean).reverse();
  document.getElementById("recentCount").textContent = list.length + " টি চ্যানেল";
  renderGrid(list, "recentGrid", { emoji: "📺", text: "এখনো কোনো চ্যানেল দেখা হয়নি।" });
}

function renderAll() {
  document.getElementById("allCount").textContent = CHANNELS.length + " টি চ্যানেল";
  renderGrid(CHANNELS, "allGrid", { emoji: "📺", text: "চ্যানেল লোড হচ্ছে..." });
}

/* =============================================
   PLAYER
   ============================================= */
function playChannel(channel) {
  currentChannel = channel;
  const ph = document.getElementById("playerPlaceholder");
  const video = document.getElementById("playerIframe");
  ph.style.display = "none";
  video.classList.add("active");

  // Destroy previous HLS instance
  if (window._hlsInstance) {
    window._hlsInstance.destroy();
    window._hlsInstance = null;
  }
  video.src = "";

  const url = channel.url;
  const isM3U8 = url.includes('.m3u8') || url.includes('/index') || url.includes('playlist');
  const isTS = url.includes('.ts') || url.includes('mono.ts');

  if ((isM3U8 || isTS) && Hls.isSupported()) {
    const hls = new Hls({
      enableWorker: true,
      lowLatencyMode: true,
      maxBufferLength: 30,
    });
    hls.loadSource(url);
    hls.attachMedia(video);
    hls.on(Hls.Events.MANIFEST_PARSED, () => { video.play().catch(()=>{}); });
    hls.on(Hls.Events.ERROR, (e, data) => {
      if (data.fatal) { console.warn('HLS fatal error', data.type); }
    });
    window._hlsInstance = hls;
  } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
    video.src = url;
    video.play().catch(()=>{});
  } else {
    // Fallback: try direct src or iframe
    video.src = url;
    video.play().catch(()=>{});
  }
  document.getElementById("nowPlayingTitle").textContent = "▶ " + channel.name;
  document.getElementById("nowPlayingTitle").classList.remove("empty");
  const favBtn = document.getElementById("favCurrentBtn");
  favBtn.textContent = favorites.includes(channel.id) ? "❤️" : "♡";

  // Add to recent
  recentList = recentList.filter(id => id !== channel.id);
  recentList.push(channel.id);
  if (recentList.length > 20) recentList.shift();
  localStorage.setItem("bf_recent", JSON.stringify(recentList));

  // Scroll to top on mobile
  if (window.innerWidth <= 768) window.scrollTo({ top: 0, behavior: "smooth" });

  // Refresh grids to show playing state
  if (currentView === "home") renderHome();
  else if (currentView === "favorites") renderFavs();
  else if (currentView === "recent") renderRecent();
  else if (currentView === "all") renderAll();
}

function goFullscreen() {
  const pw = document.getElementById("playerWrapper");
  if (document.fullscreenElement) {
    document.exitFullscreen && document.exitFullscreen();
  } else {
    (pw.requestFullscreen || pw.webkitRequestFullscreen || pw.mozRequestFullScreen).call(pw);
  }
}

/* =============================================
   FAVORITES
   ============================================= */
function toggleFav(e, id) {
  e.stopPropagation();
  if (favorites.includes(id)) {
    favorites = favorites.filter(f => f !== id);
  } else {
    favorites.push(id);
  }
  localStorage.setItem("bf_favs", JSON.stringify(favorites));
  if (currentChannel && currentChannel.id === id) {
    document.getElementById("favCurrentBtn").textContent = favorites.includes(id) ? "❤️" : "♡";
  }
  if (currentView === "home") renderHome();
  else if (currentView === "favorites") renderFavs();
  else if (currentView === "all") renderAll();
}

function toggleCurrentFav() {
  if (!currentChannel) return;
  toggleFav({ stopPropagation: () => {} }, currentChannel.id);
}

/* =============================================
   SEARCH
   ============================================= */
function handleSearch(q) {
  searchQuery = q.trim();
  if (currentView !== "home") setView("home");
  renderHome();
}
document.getElementById("searchDesktop").addEventListener("input", e => handleSearch(e.target.value));
document.getElementById("searchMobile").addEventListener("input", e => handleSearch(e.target.value));

/* =============================================
   INIT
   ============================================= */
function init() {
  buildFilterTabs();
  buildSidebarCats();
  renderHome();
}

init();
</script>
</body>
</html>
